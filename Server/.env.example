DB_NAME=
DB_USER=
DB_PASS=
DB_HOST=127.0.0.1
DB_PORT=3306

# Segredo técnico para assinar o cookie de sessão do staff. Obrigatório em produção
# (o servidor recusa arrancar sem isto quando NODE_ENV=production).
# Gera um valor aleatório, ex.: openssl rand -base64 32
COOKIE_SECRET=

# Só ativar quando o servidor estiver atrás de HTTPS (reverse proxy com certificado, etc.).
# Com HTTP simples (ex. Pi na rede local sem TLS), deixa a false — "true" faz o browser
# deixar de enviar o cookie e parte o login.
COOKIE_SECURE=false
